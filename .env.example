# Application
APP_NAME=Air Quality Monitoring System
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8050
API_HOST=0.0.0.0
API_PORT=8000

# Database
DATABASE_PATH=data/air_quality.db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# OpenAQ API
OPENAQ_API_BASE_URL=https://api.openaq.org/v3
OPENAQ_API_KEY=your_api_key_here
OPENAQ_RATE_LIMIT=10
OPENAQ_TIMEOUT=30

# Dashboard
DASH_REFRESH_INTERVAL=300
DASH_QUALITY_STALE_HOURS=24

# Authentication
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Data Export
EXPORT_MAX_ROWS=100000
EXPORT_TEMP_DIR=temp/exports

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# WebSocket
WS_HEARTBEAT_INTERVAL=30
